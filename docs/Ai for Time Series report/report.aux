\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Accuracy versus training time trade-off across configurations. The differenced channel and global z-normalization configurations achieved the best accuracy-to-time ratio. The AdamW + z-normalization experiment shows higher training time due to the Keras 3 with PyTorch backend migration used for GPU acceleration in that experiment.}}{7}{}\protected@file@percent }
\newlabel{fig:time_vs_accuracy}{{4}{7}{}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Training time comparison across configurations. Most improvement strategies maintained comparable training times to the baseline. The elevated runtime for AdamW + z-normalization reflects the different backend framework used in that experiment rather than inherent computational overhead.}}{7}{}\protected@file@percent }
\newlabel{fig:training_time}{{5}{7}{}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Accuracy distribution across 30 datasets for selected configurations. The global z-normalization and differenced channel configurations exhibit upward-shifted distributions with reduced lower-quartile spread. The AdamW + z-normalization configuration shows a comparable median but with increased upper-quartile density.}}{7}{}\protected@file@percent }
\newlabel{fig:univariate_boxplot}{{6}{7}{}{figure.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Effect of ensemble size on classification accuracy. Performance improves with increasing ensemble size before stabilizing.}}{7}{}\protected@file@percent }
\newlabel{fig:ensemble_size}{{7}{7}{}{figure.7}{}}
