\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Per-dataset accuracy improvement of the differenced channel + global z-normalization configuration relative to baseline. This best-performing configuration improved accuracy on the majority of datasets, with consistent gains across diverse time series types.}}{6}{}\protected@file@percent }
\newlabel{fig:dataset_improvement}{{3}{6}{}{figure.3}{}}
