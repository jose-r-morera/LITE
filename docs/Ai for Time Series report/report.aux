\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Per-dataset accuracy improvement across all 128 UCR datasets. The improved configuration (global z-normalization + differenced channel + AdamW) achieved higher accuracy on 73 datasets, with a mean improvement of +0.20\%. The most extreme gains exceeded +50\% (PigAirwayPressure), while the largest decrease was $-$40.9\% (PLAID).}}{8}{}\protected@file@percent }
\newlabel{fig:full_ucr_improvement}{{8}{8}{}{figure.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Accuracy distribution comparison between baseline and improved configurations across the full 128-dataset UCR archive. The improved LITE configuration shows an upward-shifted distribution with a higher median, while LITETime performance remains essentially unchanged. Gold diamonds indicate mean accuracy values.}}{8}{}\protected@file@percent }
\newlabel{fig:full_ucr_boxplot}{{9}{8}{}{figure.9}{}}
